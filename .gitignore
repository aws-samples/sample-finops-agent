# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (user-specific configurations)
*.tfvars
*.tfvars.json
!**/terraform.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration file
.terraformrc
terraform.rc

# Lock file (optional - some teams commit this)
.terraform.lock.hcl

# Terraform plan files
*.tfplan

# Lambda zip files and build artifacts
terraform/modules/lambda-proxy/*.zip
terraform/modules/mcp-lambda/.build/

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------

# Makefile environment file
terraform/config/.env
!terraform/config/.env.example

# Backups created by `make setup` wizard when reconfiguring
*.backup
*.bak

# Python virtual environments
.venv/
venv/
ENV/

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------

# VS Code
.vscode/

# JetBrains
.idea/

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
*.egg

# Ruff linter cache
.ruff_cache/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

*.log
logs/

# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------

# Never commit secrets
*.pem
*.key
credentials.json
secrets.json

# Cached OAuth access token from `make get-token` — contains a bearer token
.gateway-token.json

# Local files
CLAUDE.md
prompts/cur_analysis_report.md
