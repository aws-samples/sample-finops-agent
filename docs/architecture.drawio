        <!-- Col 3: Notes (ASCII-safe, no double-dash) -->
        <mxCell id="lg-notes-title" value="Notes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="902" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-note1" value="- Alternate auth modes: CUSTOM_JWT (Okta/Azure AD/Auth0), AWS_IAM (SigV4), NONE." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="1000" y="922" width="640" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-note2" value="- JWT tokens cached locally at .gateway-token.json (about 1 hour TTL); run &apos;make get-token&apos; to refresh." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="1000" y="942" width="640" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-note3" value="- Cross-account role has read-only scope: ce:*, athena:GetQuery*, s3:GetObject, glue:Get*." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="1000" y="962" width="640" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lg-note4" value="- Tool schemas are registered with the Gateway by scripts/update_tool_schemas.py after terraform apply." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#444444;" vertex="1" parent="1">
