        <mxCell id="lg-logs-text" value="CloudWatch Logs write (all compute)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="935" width="330" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg-verify-line" style="endArrow=classic;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;" edge="1" parent="1">
