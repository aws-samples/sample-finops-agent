        <mxCell id="lg-verify-text" value="Out-of-band verification / response (JWKS, JWT return)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="960" width="400" height="20" as="geometry" />
