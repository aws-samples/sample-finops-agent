            <mxPoint x="95" y="995" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-proxy-text" value="InvokeAgentRuntime (lambda-proxy to container)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="105" y="985" width="330" height="20" as="geometry" />
        </mxCell>

        <!-- Col 2: more line samples -->
        <mxCell id="lg-api-line" style="endArrow=none;html=1;strokeColor=#546E7A;strokeWidth=3;" edge="1" parent="1">
