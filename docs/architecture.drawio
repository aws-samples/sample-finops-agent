        <mxCell id="lg-busbar-text" value="Vertical bus-bar = shared trust relationship (one role, many callers)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="985" width="400" height="20" as="geometry" />
