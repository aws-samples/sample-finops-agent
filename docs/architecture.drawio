        <mxCell id="lg-inv-text" value="Gateway to Lambda invocation (lambda:InvokeFunction)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="105" y="960" width="400" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg-proxy-line" style="endArrow=none;html=1;strokeColor=#3F8624;strokeWidth=3;" edge="1" parent="1">
