            <mxPoint x="95" y="945" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-req-text" value="Primary MCP request (client to Gateway)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="105" y="935" width="330" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg-inv-line" style="endArrow=none;html=1;strokeColor=#FF9900;strokeWidth=3;" edge="1" parent="1">
