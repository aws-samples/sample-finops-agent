        <mxCell id="cw-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E7157B;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="cw" value="" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.cloudwatch_2;" vertex="1" parent="1">
          <mxGeometry x="60" y="578" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cw-label" value="CloudWatch Logs" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#E7157B;" vertex="1" parent="1">
          <mxGeometry x="120" y="582" width="115" height="20" as="geometry" />
        </mxCell>
        <mxCell id="cw-sub" value="Gateway, Lambda, Runtime&#xa;access + error logs" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="602" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- CloudWatch: bus-bar collecting logs from Gateway, all 4 Lambdas, Runtime -->
        <mxCell id="cw-collect" value="" style="endArrow=none;html=1;strokeColor=#E7157B;strokeWidth=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="605" as="sourcePoint" />
            <mxPoint x="240" y="605" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="cw-gateway-edge" style="endArrow=none;html=1;strokeColor=#E7157B;strokeWidth=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="gateway">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="647" y="605" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="cw-lambdas-edge" value="" style="endArrow=none;html=1;strokeColor=#E7157B;strokeWidth=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="811" y="538" as="sourcePoint" />
            <mxPoint x="811" y="605" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="cw-label-edge" value="logs (dashed pink)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=9;fontColor=#E7157B;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="290" y="590" width="250" height="20" as="geometry" />
        </mxCell>

        <!-- ===================== NUMBERED FLOW ARROWS ===================== -->

        <!-- Step 1: Client -> Cognito (fetch token) -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#DD344C;endArrow=block;endFill=1;" edge="1" parent="1" source="user" target="cognito">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a1-label" value="1. POST /oauth2/token&#xa;(client_credentials)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontColor=#DD344C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="235" y="132" width="140" height="30" as="geometry" />
        </mxCell>

        <!-- Step 2: Cognito -> Client (return JWT, dashed) -->
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#DD344C;endArrow=block;endFill=1;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="cognito" target="user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2-label" value="2. returns JWT" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="235" y="210" width="140" height="22" as="geometry" />
        </mxCell>

        <!-- Step 3: Client -> Gateway (MCP request with JWT) — routed below Cognito -->
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#232F3E;endArrow=block;endFill=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="user" target="gateway">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="370" />
              <mxPoint x="647" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a3-label" value="3. MCP request — Authorization: Bearer &lt;JWT&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#232F3E;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="340" width="330" height="22" as="geometry" />
        </mxCell>

        <!-- Step 4: Gateway verifies JWT via Cognito JWKS (dashed gray) -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#999999;endArrow=open;endFill=0;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="gateway" target="cognito">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4-label" value="4. verify JWT via JWKS discovery" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=9;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="525" y="150" width="170" height="20" as="geometry" />
        </mxCell>

        <!-- Step 5: Gateway -> Lambdas (fan-out) -->
        <mxCell id="a5a" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#FF9900;endArrow=block;endFill=1;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gateway" target="lambda-ce">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#FF9900;endArrow=block;endFill=1;exitX=1;exitY=0.55;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gateway" target="lambda-ath">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#FF9900;endArrow=block;endFill=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gateway" target="lambda-cur">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#FF9900;endArrow=block;endFill=1;exitX=1;exitY=0.95;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="gateway" target="lambda-proxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5-label" value="5. lambda:InvokeFunction&#xa;(Gateway service role)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontColor=#FF9900;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="692" y="426" width="130" height="32" as="geometry" />
        </mxCell>

        <!-- Step 6: AssumeRole bus-bar — 3 short stubs from CE/Athena/CUR Lambdas meeting at x=1085, then ONE arrow to the role -->
        <mxCell id="a6-stub-ce" style="edgeStyle=none;rounded=0;html=1;strokeWidth=2;strokeColor=#DD344C;endArrow=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="lambda-ce">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1085" y="226" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a6-stub-ath" style="edgeStyle=none;rounded=0;html=1;strokeWidth=2;strokeColor=#DD344C;endArrow=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="lambda-ath">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1085" y="302" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a6-stub-cur" style="edgeStyle=none;rounded=0;html=1;strokeWidth=2;strokeColor=#DD344C;endArrow=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="lambda-cur">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1085" y="378" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a6-crossboundary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=3;strokeColor=#DD344C;endArrow=block;endFill=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" target="xacct-role">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1085" y="302" as="sourcePoint" />
            <Array as="points">
              <mxPoint x="1300" y="302" />
              <mxPoint x="1300" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a6-label" value="6. STS AssumeRole (+ ExternalId)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#DD344C;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1170" y="176" width="240" height="22" as="geometry" />
        </mxCell>

        <!-- Step 7: lambda-proxy -> Runtime -->
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#3F8624;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="lambda-proxy" target="runtime">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a7-label" value="7. InvokeAgentRuntime" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#3F8624;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="845" y="515" width="140" height="20" as="geometry" />
        </mxCell>

        <!-- Step 8: Assumed role -> AWS APIs -->
        <mxCell id="a8-ce" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#546E7A;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="xacct-role" target="ce-api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8-s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#546E7A;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="xacct-role" target="cur-s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8-athena" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#546E7A;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="xacct-role" target="athena">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8-glue" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#546E7A;endArrow=block;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="xacct-role" target="glue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8-label" value="8. Read-only: GetCostAndUsage, GetObject, StartQueryExecution, GetTable" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#546E7A;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1490" y="232" width="170" height="56" as="geometry" />
        </mxCell>

        <!-- ===================== LEGEND (unified line-sample grammar) ===================== -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="1620" height="140" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="Legend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="886" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Col 1: flow colors (all line samples) -->
        <mxCell id="lg-auth-line" style="endArrow=none;html=1;strokeColor=#DD344C;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="55" y="920" as="sourcePoint" />
            <mxPoint x="95" y="920" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-auth-text" value="Authentication: Cognito OAuth, STS AssumeRole" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="105" y="910" width="330" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg-req-line" style="endArrow=none;html=1;strokeColor=#232F3E;strokeWidth=3;" edge="1" parent="1">
