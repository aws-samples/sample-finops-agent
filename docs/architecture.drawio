            <mxPoint x="560" y="920" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-api-text" value="Read-only AWS API calls under assumed role" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="910" width="330" height="20" as="geometry" />
