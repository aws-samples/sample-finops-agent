# AWS credentials for Makefile
# Copy this file to .env and customize

# AWS CLI profile name (from ~/.aws/credentials)
AWS_PROFILE=default

# AWS region to deploy resources
AWS_REGION=us-east-1

# n8n Cross-Account Configuration (optional)
# AWS Account ID where n8n is deployed (enables cross-account Lambda invocation)
# TF_VAR_n8n_cross_account_id=123456789012
