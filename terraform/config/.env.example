# AWS credentials for Makefile
# Copy this file to .env and customize

# -----------------------------------------------------------------------------
# Single Account Deployment (default)
# -----------------------------------------------------------------------------
# Use these settings when deploying to a single account where the gateway
# and CUR data are in the same account.

AWS_PROFILE=default
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Cross-Account Deployment (Data Collection + Management)
# -----------------------------------------------------------------------------
# For deploying to a data collection account (with CUDOS/CID/KPI dashboards)
# while accessing Cost Explorer and CUR data in the management/payer account.
#
# This follows the AWS Cloud Intelligence Dashboards architecture pattern:
# https://docs.aws.amazon.com/guidance/latest/cloud-intelligence-dashboards/cudos-cid-kpi.html
#
# Uncomment and configure both profiles - a single 'make deploy' will:
# 1. Create IAM role in management account
# 2. Deploy MCP Gateway to data collection account
# 3. Configure cross-account access automatically
#
# AWS_REGION=us-east-1
#
# # AWS_PROFILE is used by Makefile scripts (update-schemas, test-lambdas)
# # Set to data collection account where Lambda functions are deployed
# AWS_PROFILE=data_collection
#
# # Terraform provider profiles (TF_VAR_* → var.* in Terraform)
# TF_VAR_aws_profile=data_collection
# TF_VAR_management_account_profile=root

# -----------------------------------------------------------------------------
# n8n Cross-Account Configuration (optional)
# -----------------------------------------------------------------------------
# AWS Account ID where n8n is deployed (enables cross-account Lambda invocation)
# TF_VAR_n8n_cross_account_id=123456789012
